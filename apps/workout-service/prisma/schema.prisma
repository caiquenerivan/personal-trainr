generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TRAINER
  ALUNO
}

enum UF {
  AC
  AL
  AP
  AM
  BA
  CE
  DF
  ES
  GO
  MA
  MT
  MS
  MG
  PA
  PB
  PR
  PE
  PI
  RJ
  RN
  RS
  RO
  RR
  SC
  SP
  SE
  TO
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum RoutineType {
  AB
  ABC
  ABCD
  ABCDE
}

enum Day {
  A
  B
  C
  D
  E
}

model User {
  id             String                     @id @default(uuid())
  name           String
  username       String?                    @unique
  email          String                     @unique
  passwordHash   String
  role           Role                       @default(ALUNO)
  avatarUrl      String?
  phone          String?
  instagram      String?
  bio            String?
  weight         Float?
  height         Float?
  birthDate      DateTime?
  createdAt      DateTime                   @default(now())
  trainerProfile TrainerProfile?
  students       TrainerStudentConnection[] @relation("TrainerToConnection")
  trainers       TrainerStudentConnection[] @relation("StudentToConnection")
}

model TrainerProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cref            String  @unique
  crefState       UF
  crefCity        String
  experienceYears Int?
  specialties     String?
  website         String?
}

model TrainerStudentConnection {
  id        String           @id @default(uuid())
  trainerId String
  studentId String
  status    ConnectionStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  trainer   User             @relation("TrainerToConnection", fields: [trainerId], references: [id], onDelete: Cascade)
  student   User             @relation("StudentToConnection", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([trainerId, studentId])
}

model Routine {
  id        String            @id @default(uuid())
  trainerId String
  name      String
  type      RoutineType
  createdAt DateTime          @default(now())
  exercises      RoutineExercise[]
  assignments    RoutineAssignment[]
}

model RoutineAssignment {
  id         String   @id @default(uuid())
  routineId  String
  alunoId    String
  weeklyGoal Int      @default(3)
  assignedAt DateTime @default(now())
  expiresAt  DateTime
  isActive   Boolean  @default(true)
  routine    Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model Exercise {
  id               String            @id @default(uuid())
  name             String
  videoUrl         String?
  gifUrl           String?
  muscle           String?
  weightTrack      String?
  observations     String?
  routineExercises RoutineExercise[]
}

model RoutineExercise {
  id          String       @id @default(uuid())
  routineId   String
  routine     Routine      @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  day         Day
  series      Int
  reps        Int
  restTime    Int
  workoutLogs WorkoutLog[]
}

model WorkoutLog {
  id                String          @id @default(uuid())
  alunoId           String
  routineExerciseId String
  routineExercise   RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)
  weightUsed        Float?
  completedAt       DateTime        @default(now())
}
