generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TRAINER
  ALUNO
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  avatarUrl    String?
  phone        String?
  weight       Float?
  height       Float?
  birthDate    DateTime?
  createdAt    DateTime @default(now())
}
